/*Calculation of geometric means*/
data lsm2;
set lsm_mi;
length geo_m $100.;
geo_est=exp(Estimate);
geo_upper=exp(UCLMean);
geo_lower=exp(LCLMean);
geo_m=strip(put(round(geo_est,0.001),10.3)) || " (" || strip(put(round(geo_lower,0.001),10.3)) || ", " || strip(put(round(geo_upper,0.001),10.3)) || ")";
keep avisitn trt01pn geo_:;
run;

/*Calculation of geometric mean ratio to placebo*/
data diff2;
set diff_mi2;
length geo_m_ratio pval reduce $100.;
where avisitn=_avisitn;
geo_est_ratio=exp(Estimate);
geo_upper_ratio=exp(UCLMean);
geo_lower_ratio=exp(LCLMean);
geo_m_ratio=strip(put(round(geo_est_ratio,0.001),10.3)) || " (" || strip(put(round(geo_lower_ratio,0.001),10.3)) || ", " || strip(put(round(geo_upper_ratio,0.001),10.3)) || ")";
