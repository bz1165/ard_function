reduce=strip(put(round(100-geo_est_ratio*100,0.1),10.1)) || " (" || strip(put(round(100-geo_upper_ratio*100,0.1),10.1)) || ", " || strip(put(round(100-geo_lower_ratio*100,0.1),10.1)) || ")";
if . < PROBT =< 0.0001 then pval = "<0.0001";
else if . < PROBT => 0.9999 then pval = ">0.9999";
else pval = strip(put(round(PROBT,0.0001),10.4));
;
keep avisitn trt01pn geo_m_ratio pval reduce ;
run;

