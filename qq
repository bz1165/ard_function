*  MODIFICATIONS : [x.xx] dd-mmm-yy, 5-2-1 id, brief description  
	* 09Apr2024, huangy2e: update for ANL01FL logic
*************************************************************************/
/* GPS environment setup macro */;
/*Clean work library*/
proc datasets lib=work kill;
run;

data _null_;
    if libref('analysis') then call execute('%nrstr(%autorun;)');
run;

*----------------------------------------------------------------------;
				*read in adsl, upcr amd suppupcr dataset;
*----------------------------------------------------------------------;

proc format;
    invalue avisitn 
    "Baseline"  = 99
    "Day 14"    = 202
    "Day 30"   = 203
    "Day 90"    = 204
    "Day 180"   = 205
    ;
  run;

%macro uacrimpute(TPT=24H , visitlst=%str("Baseline","Day 90","Day 180") );
  /****1.1 Import dataset****/
  data dat_uacr_&tpt.;
        set analysis.adlb;
        where (paramcd in ("UACR&tpt.", "UPCR&tpt.") and avisit in (&visitlst)) and ANL01FL='Y';
        if dtype in ('AVERAGE','GEOMEAN') then prior=1;
        else prior=2;
        keep  USUBJID lbtpt avisit avisitn paramcd param aval lbstresc ablfl prior ANL01FL ADT; 
  run;
  
  /*Re-derive ANL01FL, regardless of missing baseline*/
/*  proc sort data=dat_uacrpre_&tpt.;*/
/*    by USUBJID PARAMCD AVISITN prior descending ABLFL descending ADT;*/
/*  run;*/
/*  */
/*  data dat_uacr_&tpt.;*/
/*    set dat_uacrpre_&tpt.;*/
/*    by USUBJID PARAMCD AVISITN prior descending ABLFL descending ADT;*/
/*    if first.AVISITN and (ABLFL="Y" or prxmatch("/Day/i",AVISIT)) */
/*      and ^missing(AVAL) then do;*/
/*      ANL01FL="Y";*/
/*    end;*/
/*    else do;*/
/*      ANL01FL="";*/
/*    end;*/
/*    if ANL01FL="Y";*/
/*  run;*/
  
  /*Use transpose to list all missing data*/
  proc sort data=dat_uacr_&tpt.;
  by USUBJID avisit;
  run;
  
  proc transpose data = dat_uacr_&tpt. out=dat_aval_wide_&tpt. prefix=aval;
    by USUBJID avisit;
    id paramcd;
    var aval;
  run;
  
  /*identify ALB values with >4400*/
  data dat_alb_&tpt.;
        set analysis.adlb;
        where paramcd in ("UMALB&tpt.") and (avisit in ("Day 1", &visitlst.) or VISIT="Run-In day (-15)") and lbstresc = ">4400";
        if AVISIT="Day 1" or visit= "Run-In day (-15)"  then avisit="Baseline";
        keep  USUBJID avisit paramcd param lbstresc; 
  run;
  
  proc sort data=dat_alb_&tpt. nodupkey;
  by USUBJID avisit;
  run; 
  
  /*merge to flag corresponding ALB > 4400*/
  proc sql; 
  create table dat_wide_&tpt. as
  select x.*, y.LBSTRESC from dat_aval_wide_&tpt. as x left join dat_alb_&tpt. as y
  on x.avisit = y.avisit and x.USUBJID=y.USUBJID; 
  quit;
  
  /*adding flags for missing values that needs imputation: those with corresponding ALB>4400*/
  data dat_imp_&tpt.;
  set dat_wide_&tpt.;
  resUMALB&tpt. = LBSTRESC;
  if resUMALB&tpt. = ">4400" and avalUACR&tpt. = . then flag = "Y"; 
  keep USUBJID avisit flag avalUACR&tpt. avalUPCR&tpt. resUMALB&tpt.;
  run;
  
  /*merge dataset to include covariate*/
  data dat_egfr_&tpt.;
        set analysis.adegfr;
        where ANL01FL="Y" and AVISIT in ("Baseline") and paramcd="EGFRDER";
        keep  USUBJID trt01p trt01pn base chg aval age; 
  run;
  
  data dat_str_&tpt.;
    set analysis.adbs;
    where fasfl="Y";
    keep USUBJID systrcrf;
  run;
  
  proc sql; 
  create table dat_imp2_&tpt. as
  select x.*, y.aval, z.systrcrf from dat_imp_&tpt. as x 
  left join dat_egfr_&tpt. as y
  on x.USUBJID = y.USUBJID
  left join dat_str_&tpt. as z
  on x.USUBJID = z.USUBJID;
  quit;
  
  %let selected_variables = USUBJID avisit avalUACR&tpt. avalUPCR&tpt. flag avalegfrbase SYSTRCRF;
  
  data mydata_&tpt.;
    set dat_imp2_&tpt.;
    avalegfrbase=aval; 
  run;
  
  data dat_imp3_&tpt.;
    set mydata_&tpt. (keep=&selected_variables.);
  run;
  
  
  /**Mark the imputation methods according to SAP**/
  data uacr_mi_&tpt.;
    set dat_imp3_&tpt.;
    if systrcrf="" then systrcrf="N";
    if avalUACR&tpt.=. then do imp_method="ALMCF"; end;
    if flag = "Y" then do imp_method="MAR"; end;
    avisitn=input(avisit,avisitn.);
  run;

  proc sort data=uacr_mi_&tpt.;
    by USUBJID avisitn;
  run;
  
  /***2.2Imputation step***/
  /**imputation model: UACR=visit+UPCR+egfr_base**/
  proc mi data=uacr_mi_&tpt. seed=999 nimpute=200 out=uacr_out_&tpt.;
  class avisit;
  fcs nbiter=20 reg (avalUACR&tpt.=avalUPCR&tpt. avalegfrbase avisit /details);;
  var avalUACR&tpt. avalUPCR&tpt. avalegfrbase avisit;
  run;
  
  proc sort data=uacr_out_&tpt.;
    by USUBJID;
  run;
  
  /*recover missing due to administrative reasons as missing status*/
  data uacr_imped_&tpt.;
     merge uacr_out_&tpt.(in=a) analysis.adsl(in=b);
     by USUBJID;
     if a;
     if imp_method="ALMCF" then do avalUACR&tpt.=.; imp_method=''; end;
     aval = avalUACR&tpt.;
     IMPNUM = _Imputation_;
     DTYPE=imp_method;
     length PARAM $200. PARAMCD $8.;
     %if &tpt=24H %then %do;
     PARAM="UACR 24 hour collection (g/g)";
     PARAMCD="UACR24H";
     %end;
     %else %if &tpt=FMV %then %do;
     PARAM="UACR FMV collection (g/g)";
     PARAMCD="UACRFMV";
     %end;

  run;
  
  /*Derive UACR log*/
  data uacr_log_&tpt.;
    set uacr_imped_&tpt.;
     %if &tpt=24H %then %do;
     PARAM="Log-transformed UACR 24 hour collection (g/g)";
     PARAMCD="LGUACR24";
     %end;
     %else %if &tpt=FMV %then %do;
     PARAM="Log-transformed UACR FMV collection (g/g)";
     PARAMCD="LGUACRFV";
     %end;
     if ^missing(AVAL) then AVAL=log(AVAL);
   run;
  
   /*Combination and baseline*/
  
   data aduarmi1_&tpt.;
    set uacr_imped_&tpt. uacr_log_&tpt.;
    AVISITN=input(AVISIT,avisitn.);
    if AVISIT="Baseline" then ABLFL="Y";
  proc sort;
    by USUBJID PARAMCD AVISITN IMPNUM;
  run;
  
  proc sql;
    create table aduarmi2_&tpt. as 
    select a.*, b.AVAL as BASE, case when a.ABLFL="" then a.AVAL-b.AVAL else . end as chg
    from aduarmi1_&tpt. as a 
    left join aduarmi1_&tpt.(where=(ABLFL="Y")) as b 
    on a.USUBJID=b.USUBJID and a.PARAMCD=b.PARAMCD and a.IMPNUM=b.IMPNUM
    ;
  quit;

%mend;


%uacrimpute(TPT=24H , visitlst=%str("Baseline","Day 90","Day 180") );
%uacrimpute(TPT=FMV , visitlst=%str("Baseline","Day 14","Day 30","Day 90","Day 180") );

data aduarmi_final;
  set aduarmi2_24h aduarmi2_fmv;
run;

