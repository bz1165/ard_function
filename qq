*  FILENAME      : adfacit.sas
*  DESCRIPTION   : Create dataset ADFACIT (csr_4 PDS / VLM / METHOD compliant)
*  PLATFORM      : AIX 7.1 (AIX 64) (see SAS log file)
*  SAS VERSION   : 9.4 (see SAS log file)
*  INPUT         : SDTM QS (with SUPPQS), ADaM ADSL, SDTM DS/FACM
*  OUTPUT        : analysis.adfacit
*************************************************************************/

proc datasets lib=work kill nolist; quit;

/* GPS environment setup macro */
data _null_;
  if libref('analysis') then call execute('%nrstr(%autorun;)');
run;

/* 5-point verbal scale to numeric (fallback when QSSTRESN missing) */
proc format;
  invalue facit_val
    "NOT AT ALL"   = 0
    "A LITTLE BIT" = 1
    "SOMEWHAT"     = 2
    "QUITE A BIT"  = 3
    "VERY MUCH"    = 4
  ;
quit;

/* ------------------------------- */
/* Read QS  SUPPQS and pre-derive  */
/* ------------------------------- */
%opMergeSupp(
  inData     = derived.qs,
  outData    = qs_raw,
  inSuppData = derived.suppqs,
  keepQnam   =
);

proc sort data=qs_raw nodupkey;
  by usubjid subjid qscat qstest qsscat visit qsdtc qsorres;
run;

/* Keep only FACIT-Fatigue 13 items */
data qs_items;
  set qs_raw(rename=(qstest=param qstestcd=paramcd lg=qslg qseval=qseval));
  where qscat = 'FACIT-FATIGUE 13-ITEM V4';

  length avalc $100;
  aval  = coalesce(qsstresn, input(upcase(qsorres), facit_val.));
  avalc = strip(upcase(qsorres));

  /* Date/time */
  adt = input(scan(qsdtc,1,'T'), yymmdd10.);
  atm = input(scan(qsdtc,2,'T'), time8.);
  if length(qsdtc)=19 then adtm = input(qsdtc, e8601dt.);
  format adt yymmdd10. atm time5.;
run;

/* Map PARAMN from Analysis Parameters (item-level) */
proc sql;
  create table qs_items_m as
  select a.*
       , b.paramcd as paramcd_
       , b.paramn
  from qs_items as a
  left join
       (select param, paramcd, paramn
          from rprtdsm.analysis_parameters
         where not missing(paramn)) as b
    on a.param = b.param
  ;
quit;

proc sort data=qs_items_m;
  by usubjid subjid visit adt paramn;
run;

/* ------------------------------- */
/* Join ADSL and derive ADY/APERIOD */
/* ------------------------------- */
data qs_items_j;
  merge qs_items_m(in=a)
        analysis.adsl(in=b drop=subjid);
  by usubjid;
  if a;

  /* ADY */
  if adt>=trtsdt>. then ady = adt - trtsdt + 1;
  else if .<adt<trtsdt then ady = adt - trtsdt;

  /* APERIOD per PDS */
  if aperiod = . then do;
    if .< ap01sdt <= adt <= coalesce(ap02sdt, ap01edt) then aperiod = 1;
    else if .< ap02sdt <  adt <= ap02edt              then aperiod = 2;
  end;

  length aperiodc $30;
  if aperiod=1 then aperiodc='Double-blind';
  else if aperiod=2 then aperiodc='Open-label';
run;

/* ------------------------------- */
/* Derive FACIT/FACITEXP/FACITIMP */
/* ------------------------------- */
proc sort data=qs_items_j;
  by studyid usubjid subjid visit visitnum adt atm adtm qslg qseval;
run;

proc transpose data=qs_items_j(where=(not missing(paramcd_)))
               out=qs_wide(drop=_name_);
  by studyid usubjid subjid visit visitnum adt atm adtm qslg qseval;
  var aval;
  id paramcd_;
run;

/* Compute scores per METHOD */
data facit_der;
  length param $40 paramcd $8 paramtyp $7 avalc $100;
  set qs_wide;

  array ITEM  {13} FAC07001-FAC07013;

  do i=1 to 13;
    if ITEM[i] in (8,9) then ITEM[i]=.;
  end;

  if not missing(FAC07001) then HI7  = 4 - FAC07001;
  if not missing(FAC07002) then HI12 = 4 - FAC07002;
  if not missing(FAC07003) then AN1  = 4 - FAC07003;
  if not missing(FAC07004) then AN2  = 4 - FAC07004;
  if not missing(FAC07005) then AN3  = 4 - FAC07005;
  if not missing(FAC07006) then AN4  = 4 - FAC07006;
  if not missing(FAC07007) then AN5  =      FAC07007;
  if not missing(FAC07008) then AN7  =      FAC07008;
  if not missing(FAC07009) then AN8  = 4 - FAC07009;
  if not missing(FAC07010) then AN12 = 4 - FAC07010;
  if not missing(FAC07011) then AN14 = 4 - FAC07011;
  if not missing(FAC07012) then AN15 = 4 - FAC07012;
  if not missing(FAC07013) then AN16 = 4 - FAC07013;

  FAT_N = n(of HI7 HI12 AN1-AN5 AN7 AN8 AN12 AN14-AN16);

  if FAT_N/13 > .50 then do;
    aval  = sum(of HI7 HI12 AN1-AN5 AN7 AN8 AN12 AN14-AN16) * 13 / FAT_N;
    avalc = strip(put(aval,best.));
    param='FACIT Fatigue score'; paramcd='FACIT'; paramtyp='DERIVED'; output;

    aval  = sum(of HI7 HI12 AN1 AN2 AN5);
    avalc = strip(put(aval,best.));
    param='FACIT Experience score'; paramcd='FACITEXP'; paramtyp='DERIVED'; output;

    aval  = sum(of AN3 AN4 AN7 AN8 AN12 AN14-AN16);
    avalc = strip(put(aval,best.));
    param='FACIT Impact score'; paramcd='FACITIMP'; paramtyp='DERIVED'; output;
  end;

  keep studyid usubjid subjid visit visitnum adt atm adtm qslg qseval param paramcd paramtyp aval avalc;
run;

/* Map PARAMN for derived rows */
proc sql;
  create table facit_der_m as
  select a.*, b.paramn
  from facit_der as a
  left join
       (select param, paramcd, paramn
          from rprtdsm.analysis_parameters
         where not missing(paramn)) as b
    on a.param = b.param and a.paramcd = b.paramcd
  ;
quit;

/* ------------------------------- */
/* Union items + derived, join ADSL */
/* ------------------------------- */
data adfacit0;
  set qs_items_j(in=i keep=studyid usubjid subjid siteid param paramcd paramn
                        visit visitnum adt atm adtm qslg qseval aval avalc qsseq
                        ady aperiod aperiodc
                )
      facit_der_m(in=d);
run;

proc sort data=adfacit0; by usubjid; run;

data adfacit1;
  merge adfacit0(in=a)
        analysis.adsl(in=b drop=subjid rename=(siteid=siteid_adsl));
  by usubjid;
  if a;

  if missing(siteid) then siteid = siteid_adsl;
  drop siteid_adsl;

  /* Recompute ADY just in case */
  if adt>=trtsdt>. then ady = adt - trtsdt + 1;
  else if .<adt<trtsdt then ady = adt - trtsdt;

  /* Clean QS vars for derived */
  if upcase(coalescec(paramtyp,'')) = 'DERIVED' then do;
    qsstat = ''; qsreasnd = ''; qslg=''; qseval='';
  end;

  /* AVISIT/AVISITN per csr_4 PDS:
     - Baseline later after ABLFL
     - planned visits: carry VISIT to AVISIT and VISITNUM to AVISITN
     - non-planned: null
     - will not be populated at pre-baseline records */
  length avisit $40;
  if visit = 'End of Study' then avisit = 'Day 360/EOS';
  else if visit in ('Day 1','Day 14','Day 30','Day 90','Day 180','Day 210','Day 270','Day 360') then avisit = visit;
  else avisit = '';

  if avisit ne '' and adt>=trtsdt>. then avisitn = visitnum;
  else if avisit ne '' and adt<trtsdt then call missing(avisitn);
  else call missing(avisitn);

run;

/* ------------------------------- */
/* Baseline: last non-missing AVAL before/at TRTSDT, by USUBJID+PARAMCD */
/* ------------------------------- */
proc sort data=adfacit1; by usubjid paramcd adt atm adtm; run;

data base_cand;
  set adfacit1;
  where adt <= trtsdt and not missing(aval);
run;

proc sort data=base_cand;
  by usubjid paramcd adt atm;
run;

data base_last;
  set base_cand;
  by usubjid paramcd adt atm;
  if last.paramcd;
  keep usubjid paramcd adt atm aval;
  rename adt = baseadt
         atm = basetm
         aval= base;
run;

proc sql;
  create table adfacit2 as
  select a.*, b.base, b.baseadt, b.basetm
  from adfacit1 as a
  left join base_last as b
    on a.usubjid=b.usubjid and a.paramcd=b.paramcd
  ;
quit;

/* ABLFL, BASE, CHG, CRIT1/2, TRTA/TRTP, ANL01/03 */
data adfacit3;
  length ablfl $1 crit1 crit2 $50
         anl01fl anl03fl $1 anl01dsc anl03dsc $100;
  set adfacit2;

  /* Identify baseline record: last non-missing before/at TRTSDT */
  if not missing(baseadt) and adt = baseadt and (missing(basetm) or atm = basetm) then do;
    ablfl  = 'Y';
    avisit = 'Baseline';
    avisitn= 99;
  end;

  /* BASE populate for baseline and all post-baseline records */
  /* (BASE already merged; keep as-is) */

  /* CHG only for derived params and post-baseline */
  if upcase(coalescec(paramtyp,''))='DERIVED' then do;
    if ablfl ne 'Y' and nmiss(aval, base)=0 then chg = aval - base;
  end;

  /* Criteria flags */
  if not missing(chg) then do;
    if chg >= 5 then do; crit1fl='Y'; crit1='5-point improvement'; end;
    else call missing(crit1, crit1fl);

    if chg >= 3 then do; crit2fl='Y'; crit2='3-point improvement'; end;
    else call missing(crit2, crit2fl);
  end;
  else call missing(crit1,crit1fl,crit2,crit2fl);

  /* TRTA/TRTP per PDS */
  if aperiod=1 or ablfl='Y' then do; trta=trt01a; trtan=trt01an; trtp=trt01p; trtpn=trt01pn; end;
  else if aperiod=2         then do; trta=trt02a; trtan=trt02an; trtp=trt02p; trtpn=trt02pn; end;

  /* ANL03FL: baseline and all post-baseline assessment done in randomized period */
  if (ablfl='Y' or aperiod=1) and not missing(aval) then do;
    anl03fl='Y';
    anl03dsc='Record for treatment randomized period analysis';
  end;

run;

/* ANL01FL: unique record for each visit for derived params (baseline + unique non-missing per AVISITN) */
proc sort data=adfacit3 out=der_cand;
  by usubjid paramcd avisitn adt atm;
  where upcase(coalescec(paramtyp,''))='DERIVED' and not missing(avisitn) and not missing(aval);
run;

data der_last;
  set der_cand;
  by usubjid paramcd avisitn adt atm;
  if last.avisitn;
  keep usubjid paramcd avisitn adt atm;
run;

proc sql;
  create table adfacit3a as
  select a.*,
         case when b.usubjid is not null then 'Y' else '' end as anl01fl length=1,
         case when b.usubjid is not null then 'Unique record for each visit' else '' end as anl01dsc length=100
  from adfacit3 as a
  left join der_last as b
    on a.usubjid=b.usubjid and a.paramcd=b.paramcd and a.avisitn=b.avisitn and a.adt=b.adt and a.atm=b.atm
  ;
quit;

/* ------------------------------- */
/* ANL05DT/ANL06DT from FACM; ANL07DT from DS  (subject level earliest on/after TRTSDT) */
/* ------------------------------- */

/* ANL05DT: anti-proteinuric therapies */
data fa_ap;
  merge derived.facm(in=a) analysis.adsl(keep=usubjid subjid trtsdt);
  by usubjid subjid;
  if a and upcase(facat)='ANTI-PROTEINURIC THERAPIES RELATED INTERCURRENT EVENTS' and faorres='Y';
  anl05dt = input(fadtc, ??yymmdd10.);
  if anl05dt>=trtsdt>.;
  format anl05dt date9.;
  keep usubjid subjid anl05dt;
run;
proc sort data=fa_ap; by usubjid subjid anl05dt; run;
data fa_ap1; set fa_ap; by usubjid subjid anl05dt; if first.subjid; run;

/* ANL06DT: RRT */
data fa_rr;
  merge derived.facm(in=a) analysis.adsl(keep=usubjid subjid trtsdt);
  by usubjid subjid;
  if a and upcase(facat)='RENAL REPLACEMENT THERAPY RELATED INTERCURRENT EVENTS' and faorres='Y';
  anl06dt = input(fadtc, ??yymmdd10.);
  if anl06dt>=trtsdt>.;
  format anl06dt date9.;
  keep usubjid subjid anl06dt;
run;
proc sort data=fa_rr; by usubjid subjid anl06dt; run;
data fa_rr1; set fa_rr; by usubjid subjid anl06dt; if first.subjid; run;

/* ANL07DT: treatment discontinuation other reason */
data ds_oth;
  merge derived.ds(in=a) analysis.adsl(keep=usubjid subjid trtsdt);
  by usubjid subjid;
  if a and dsscat in ("BLINDED TREATMENT DISPOSITION","OPEN LABEL TREATMENT DISPOSITION")
       and prxmatch('/COMPLETED|ADVERSE/i', dsdecod)=0;
  anl07dt = input(dsstdtc, ??yymmdd10.);
  if anl07dt>=trtsdt>.;
  format anl07dt date9.;
  keep usubjid subjid anl07dt;
run;
proc sort data=ds_oth; by usubjid subjid anl07dt; run;
data ds_oth1; set ds_oth; by usubjid subjid anl07dt; if first.subjid; run;

/* Attach ANL05/06/07 and set record-level flags */
proc sql;
  create table adfacit4 as
  select a.*,
         b.anl05dt,
         c.anl06dt,
         d.anl07dt
  from adfacit3a as a
  left join fa_ap1  as b on a.usubjid=b.usubjid and a.subjid=b.subjid
  left join fa_rr1  as c on a.usubjid=c.usubjid and a.subjid=c.subjid
  left join ds_oth1 as d on a.usubjid=d.usubjid and a.subjid=d.subjid
  ;
quit;

data adfacit5;
  length anl05fl anl06fl anl07fl $1 anl05dsc anl06dsc anl07dsc $100;
  set adfacit4;

  if not missing(anl05dt) and anl05dt>=trtsdt and not missing(adt) and adt>anl05dt then do;
    anl05fl='Y';
    anl05dsc='Record after initiation or intensification of anti-proteinuric therapies';
  end;

  if not missing(anl06dt) and anl06dt>=trtsdt and not missing(adt) and adt>anl06dt then do;
    anl06fl='Y';
    anl06dsc='Record after initiation of RRT';
  end;

  if not missing(anl07dt) and anl07dt>=trtsdt and not missing(adt) and adt>anl07dt then do;
    anl07fl='Y';
    anl07dsc='Record after treatment discontinuation for any other reason';
  end;
run;

/* ------------------------------- */
/* AEFLAG/AEDCDT: Study DC due to AE or renal death in period 1 */
/* ------------------------------- */
data ds_ae_p1;
  merge derived.ds(in=a) analysis.adsl(keep=usubjid subjid ap01sdt ap01edt);
  by usubjid subjid;
  if a and dsscat="STUDY DISPOSITION" and dscat="DISPOSITION EVENT" and find(upcase(dsdecod),"ADVERSE");
  aedcdt = input(dsstdtc, ??yymmdd10.);
  if ap01sdt<=aedcdt<=ap01edt;
  format aedcdt date9.;
  keep usubjid subjid aedcdt;
run;

proc sort data=ds_ae_p1 nodupkey; by usubjid subjid; run;

proc sql;
  create table adfacit6 as
  select a.*,
         e.aedcdt,
         case when not missing(e.aedcdt) then 'Y' else '' end as aeflag length=1
  from adfacit5 as a
  left join ds_ae_p1 as e
    on a.usubjid=e.usubjid and a.subjid=e.subjid
  ;
quit;

/* ------------------------------- */
/* New csr_4 vars: EST01STP/ICE01F/IMPREA01, EST02STP/ICE02F/IMPREA02 */
/* Only for PARAMCD='FACIT' per PDS text you provided */
/* ------------------------------- */
data final;
  length est01stp est02stp $200 ice01f ice02f $1 imprea01 imprea02 $200;
  set adfacit6;

  if paramcd='FACIT' then do;
    /* Default */
    ice01f='N'; ice02f='N';
    call missing(est01stp, est02stp, imprea01, imprea02);

    /* Estimand 01:
       - Anti-proteinuric therapies or RRT -> Hypothetical strategy
       - Treatment discontinuation other reason -> Treatment policy
       ICE01F=Y if record after any relevant I/C
    */
    if not missing(adt) then do;
      if (not missing(anl05dt) and adt>anl05dt) or (not missing(anl06dt) and adt>anl06dt) then do;
        est01stp='Hypothetical strategy'; ice01f='Y'; imprea01='Post ICE';
      end;
      else if (not missing(anl07dt) and adt>anl07dt) then do;
        est01stp='Treatment policy'; ice01f='Y'; imprea01='Post ICE';
      end;
      else if missing(aval) then imprea01='Missing data';
    end;
    else do;
      /* If ADT missing, we can only tag Missing data (no visit date to evaluate ICE) */
      if missing(aval) then imprea01='Missing data';
    end;

    /* Estimand 02:
       - RRT -> Hypothetical strategy
       - Anti-proteinuric therapies or Treatment discontinuation other reason -> Treatment policy
       ICE02F=Y if record after any relevant I/C
    */
    if not missing(adt) then do;
      if (not missing(anl06dt) and adt>anl06dt) then do;
        est02stp='Hypothetical strategy'; ice02f='Y'; imprea02='Post ICE';
      end;
      else if ( (not missing(anl05dt) and adt>anl05dt) or (not missing(anl07dt) and adt>anl07dt) ) then do;
        est02stp='Treatment policy'; ice02f='Y'; imprea02='Post ICE';
      end;
      else if missing(aval) then imprea02='Missing data';
    end;
    else do;
      if missing(aval) then imprea02='Missing data';
    end;

  end;

run;

proc sort data=final;
  by studyid usubjid subjid param avisitn adt;
run;

