PDS更新了，然后ADUPCR， ADUPRMI也先出了一版，你可以参考，大概的逻辑就是我们之前是在MI里面dummy了planed的visit，现在给换成在原始的数据集里给先dummy好，这样MI里就可以直接用。然后就是加了几个变量。我先给你现在ADUPCR的code /************************************************************************
*  PROJECT       : CLNP023B1
*  STUDY         : CLNP023B12301
*  RA            : csr_4
*  FILENAME      : adupcr.sas

*  DATE CREATED  : 10Mar2026
*  AUTHOR        : Huiyu Luo

*  DESCRIPTION   : Create dataset ADUPCR
*  PLATFORM      : AIX 7.2 (AIX 64) (see SAS log file)
*  SAS VERSION   : 9.4 (see SAS log file)

*  MACROS CALLED : None
*  INPUT         : ADLB, ADSL
*  OUTPUT        : analysis.adupcr

*  MODIFICATIONS : [x.xx] dd-mmm-yy, 5-2-1 id, brief description  
*************************************************************************/

/*Clean work library*/
proc datasets lib=work kill;
run;

/* GPS environment setup macro */;
data _null_;
    if libref('analysis') then call execute('%nrstr(%autorun;)');
run;

*----------------------------------------------------------------------;
				*read in adsl, adlb dataset;
*----------------------------------------------------------------------;
data adupcr1_1;
  set analysis.adlb;
  where PARAMCD in ('UPCRFMV','UPCR24H') and FASFL="Y"
  and VISIT not in ("Lab results at the time of diagnosis for C3G Medical History","Renal Complement Pathway Hx");
  if nmiss(AVAL, BASE)=0 and AVISITN^=99 then R2BASE=AVAL/BASE;
  if BASE not in (.,0) and AVISITN^=99 then PCHG=(AVAL-BASE)/BASE*100;
run;

data adupcr1_2;
  set analysis.adlb;
  where PARAMCD in ('UPCRFMV','UPCR24H') and FASFL="Y"
  and VISIT not in ("Lab results at the time of diagnosis for C3G Medical History","Renal Complement Pathway Hx");
  if PARAMCD="UPCRFMV" then do;
    PARAM="Log-transformed UPCR FMV collection (g/g)";
    PARAMCD="LGUPCRFV";
  end;
  else if PARAMCD="UPCR24H" then do;
    PARAM="Log-transformed UPCR 24 hour collection (g/g)";
    PARAMCD="LGUPCR24";
  end;

  array num [*] AVAL BASE;
  do i=1 to dim(num);
    if ^missing(num{i}) then num{i}=log(num{i});
  end;

  if nmiss(AVAL, BASE)=0 and AVISITN^=99 then CHG=AVAL-BASE;
  if nmiss(AVAL, BASE)=0 and AVISITN^=99 then R2BASE=AVAL/BASE;
  if BASE not in (.,0) then PCHG=(AVAL-BASE)/BASE*100;
run;

proc sort data=adupcr1_2 out=lgupcr24 nodupkey;by usubjid paramcd; where paramcd='LGUPCR24' and avisit='Baseline';run;
proc sort data=adupcr1_2 out=lgupcrfv nodupkey;by usubjid paramcd; where paramcd='LGUPCRFV' and avisit='Baseline';run;

data dummy_lgupcr24;
  set lgupcr24(keep= usubjid  param paramcd BASE);
  do avisit="Baseline","Day 90","Day 180";
    output;
  end;
run;

data dummy_lgupcrfv;
  set lgupcrfv(keep= usubjid  param paramcd BASE);
  do avisit="Baseline","Day 14","Day 30","Day 90","Day 180";
    output;
  end;
run;

/*set the order of visit*/
proc format;
 invalue avisit
 "Baseline"=99
 "Day 14"=202
 "Day 30"=203
 "Day 90"=204
 "Day 180"=205;
run;

data dummy;
  set dummy_lgupcr24 dummy_lgupcrfv;
  AVISITN=input(AVISIT,avisit.);
run;

/*Merge visit date and treatment start date for further step*/
proc sql;
	create table dummy_visit as 
	select a.*, input(b.SVSTDTC,yymmdd10.) as SVSTDT format=date9., c.VISITDY, d.*
	from dummy as a 
	left join derived.sv as b 
	on a.USUBJID=b.USUBJID and a.AVISIT=b.VISIT 
	left join derived.tv as c 
	on a.AVISIT=c.VISIT
	left join analysis.adsl as d 
	on a.USUBJID=d.USUBJID
	;
quit;

data dummy_final;
  format plandt padt date9.;
  set dummy_visit;
  if nmiss(TRTSDT,VISITDY)=0 then plandt=TRTSDT+VISITDY-1;
  padt=coalesce(SVSTDT, plandt);
run;

proc sort data=dummy_final;by usubjid paramcd avisitn;run;
proc sort data=adupcr1_2;by usubjid paramcd avisitn;run;

data adupcr1_3;
  merge dummy_final(in=b) adupcr1_2;
  by usubjid paramcd avisitn;
/*  if b;*/
run;

data adupcr2;
  set adupcr1_1 adupcr1_3;
  obs=_N_;
run;


/**************Intercurrent Events*************/

/*The initiation or intensification of anti-proteinuric therapies*/
data ant_cm;
  merge derived.facm(where=(FACAT="ANTI-PROTEINURIC THERAPIES RELATED INTERCURRENT EVENTS" and FAORRES="Y" )) 
  analysis.adsl(in=a keep=USUBJID subjid TRTSDT FASFL);
  by USUBJID subjid;
  if a;
  ASTDT=input(FADTC,??yymmdd10.);
  if ASTDT>=TRTSDT>.;
  keep USUBJID subjid ASTDT;
run;

proc sql;
  create table cmdt as 
  select distinct USUBJID, subjid, ASTDT 
  from ant_cm
  group by USUBJID, subjid
  having ASTDT=min(ASTDT)
  ;

  create table adupcr3 as 
  select a.*, b.ASTDT as ASTDT_CM
  from adupcr2 as a 
  left join cmdt as b 
  on a.USUBJID=b.USUBJID and a.subjid=b.subjid/*  and a.ADT>b.ASTDT>. */
  ;
quit;

/*The initiation of RRT (i.e., hemodialysis or transplant)*/
data rrt;
  merge derived.facm(where=(FACAT="RENAL REPLACEMENT THERAPY RELATED INTERCURRENT EVENTS" and FAORRES="Y")) 
  analysis.adsl(in=a keep=USUBJID subjid TRTSDT FASFL);
  by USUBJID subjid;
  if a;
  ASTDT=input(FADTC,??yymmdd10.);
  if ASTDT>=TRTSDT>.;
  keep USUBJID subjid ASTDT;
run;

proc sql;
  create table prdt as 
  select distinct USUBJID,subjid, ASTDT 
  from rrt
  group by USUBJID, subjid
  having ASTDT=min(ASTDT)
  ;

  create table adupcr4 as 
  select a.*, b.ASTDT as ASTDT_PR
  from adupcr3 as a 
  left join prdt as b 
  on a.USUBJID=b.USUBJID and a.subjid=b.subjid/* and a.ADT>b.ASTDT>. */
  ;
quit;

/*EOT due to other reason*/
data eot;
  merge derived.ds(where=(DSSCAT in ("BLINDED TREATMENT DISPOSITION") and prxmatch("/COMPLETED|ADVERSE/",DSDECOD)=0)) 
  analysis.adsl(in=a keep=USUBJID subjid TRTSDT FASFL);
  by USUBJID subjid ;
  if a;
  ASTDT=input(DSSTDTC,??yymmdd10.);
  if ASTDT>=TRTSDT>.;
  keep USUBJID subjid ASTDT;
run;

proc sql;
  create table eotdt as 
  select distinct USUBJID,subjid, ASTDT 
  from eot
  group by USUBJID, subjid
  having ASTDT=min(ASTDT)
  ;

  create table adupcr5 as 
  select a.*, b.ASTDT as ASTDT_EOT
  from adupcr4 as a 
  left join eotdt as b 
  on a.USUBJID=b.USUBJID and a.subjid=b.subjid /* and a.ADT>b.ASTDT>. */
  ;
quit;


/*Study DC due to AE or renal death*/
data dsae;
  merge derived.ds(where=(DSSCAT="STUDY DISPOSITION" and DSCAT="DISPOSITION EVENT" and find(DSDECOD,"ADVERSE")))
  analysis.adsl(in=a keep=USUBJID subjid AP01SDT AP01EDT);
  by USUBJID subjid;
  if a;
  ASTDT=input(DSSTDTC,??yymmdd10.);
  if AP01SDT<=ASTDT<=AP01EDT;
  keep USUBJID subjid ASTDT DSDECOD;
run;


proc sql;
  create table adupcr6 as 
  select a.*, b.ASTDT as ASTDT_DS
  from adupcr5 as a 
  left join dsae as b 
  on a.USUBJID=b.USUBJID and a.subjid=b.subjid
  ;

quit;


data adupcr_final;
  length CRIT1 CRIT2 IMPREA01 IMPREA02 IMPREA03 $200.;
  set adupcr6;
  if paramcd='LGUPCR24' then do;
    if adt>astdt_cm>. then do;EST01STP='Hypothetical strategy'; ICE01F='Y'; IMPREA01='Post ICE';EST02STP='Treatment policy'; ICE02F='Y'; IMPREA02='Post ICE';end;
    else if adt>astdt_pr>. then do;EST01STP='Hypothetical strategy'; ICE01F='Y'; IMPREA01='Post ICE'; EST02STP='Hypothetical strategy'; ICE02F='Y'; IMPREA02='Post ICE';end;
	else if adt>ASTDT_EOT>. then do;EST01STP='Treatment policy'; ICE01F='Y';IMPREA01='Post ICE';EST02STP='Treatment policy'; ICE02F='Y';IMPREA02='Post ICE';end;
	if aval=. then do;IMPREA01='Missing data';IMPREA02='Missing data';end;
	if adt=. then do;
      if padt>astdt_cm>. then do;EST01STP='Hypothetical strategy'; ICE01F='Y'; IMPREA01='Post ICE';EST02STP='Treatment policy'; ICE02F='Y'; IMPREA02='Post ICE';end;
      else if padt>astdt_pr>. then do;EST01STP='Hypothetical strategy'; ICE01F='Y'; IMPREA01='Post ICE';EST02STP='Hypothetical strategy'; ICE02F='Y'; IMPREA02='Post ICE';end;
	  else if padt>ASTDT_EOT>. then do;EST01STP='Treatment policy'; ICE01F='Y';IMPREA01='Post ICE';EST02STP='Treatment policy'; ICE02F='Y';IMPREA02='Post ICE';end;
	end;
  end;
  if paramcd='LGUPCRFV' then do;
    if adt>astdt_cm>. then do;EST03STP='Hypothetical strategy'; ICE03F='Y'; IMPREA03='Post ICE';end;
    else if adt>astdt_pr>. then do;EST03STP='Hypothetical strategy'; ICE03F='Y'; IMPREA03='Post ICE';end;
	else if adt>ASTDT_EOT>. then do;EST03STP='Treatment policy'; ICE03F='Y';IMPREA03='Post ICE';end;
	if aval=. then IMPREA03='Missing data';
	if adt=. then do;
      if padt>astdt_cm>. then do;EST03STP='Hypothetical strategy'; ICE03F='Y'; IMPREA03='Post ICE';end;
      else if padt>astdt_pr>. then do;EST03STP='Hypothetical strategy'; ICE03F='Y'; IMPREA03='Post ICE';end;
	  else if padt>ASTDT_EOT>. then do;EST03STP='Treatment policy'; ICE03F='Y';IMPREA03='Post ICE';end;
	end;
  end;
  ANL05DT=ASTDT_CM;
  ANL06DT=ASTDT_PR;
  ANL07DT=ASTDT_EOT;
  AEDCDT=ASTDT_DS;
  if ADT>ASTDT_CM>. then do;
    ANL05FL="Y";
    ANL05DSC="Record after initiation or intensification of anti-proteinuric therapies";
  end;
  if ADT>ASTDT_PR>. then do;
    ANL06FL="Y";
    ANL06DSC="Record after initiation of RRT";
  end;
  if ADT>ASTDT_EOT>. then do;
    ANL07FL="Y";
    ANL07DSC="Record after treatment discontinuation for any other reason";
  end;
  if ASTDT_DS^=. then AEFLAG="Y";
  if nmiss(CHG,BASE)=0 and AVISITN^=99 then PCHG=CHG/BASE*100;
  if .<PCHG<=-50 and PARAMCD="UPCR24H" then do;
    CRIT1= ">=50% reduction in UPCR 24 hour collection";
    CRIT1FL="Y";
  end;
  else call missing(CRIT1, CRIT1FL);
run;

