```

**`btnSubmitToXiaoran.OnSelect`**
```powerapps
With(
    {
        _batchID: "BAT-" & Text(Now(), "[$-en-US]yyyymmddhhmmss"),
        _changes: Filter(colManagerScopes, SelectedAction <> "No Change")
    },
    If(
        CountRows(_changes) = 0,
        Notify(
            "Please select at least one Add or Drop action.",
            NotificationType.Warning
        ),
        IfError(
            Patch(
                Batches,
                Defaults(Batches),
                {
                    Title:                 _batchID,
                    BatchID:               _batchID,
                    PolicyEventID:         varSelectedPolicyEventID,
                    SystemCode:            varSelectedSystemCode,
                    ManagerEmail:          User().Email,
                    ManagerName:           varManagerName,
                    SubmittedAt:           Now(),
                    Status:                "Pending",
                    AddCount:              CountIf(_changes, SelectedAction = "Add"),
                    DropCount:             CountIf(_changes, SelectedAction = "Drop"),
                    TotalLines:            CountRows(_changes),
                    ExpectedTicketCount:
                        CountRows(
                            Distinct(
                                AddColumns(
                                    _changes,
                                    TicketGroupKey,
                                    SystemCode & "|" & SelectedAction & "|" &
                                    TargetTA & "|" & Environment
                                ),
                                TicketGroupKey
                            )
                        ),
                    ApprovalFileURL:       Blank(),
                    LastError:             Blank()
                }
            );

            ForAll(
                _changes As scopeLine,
                Patch(
                    BatchLines,
                    Defaults(BatchLines),
                    {
                        Title:         _batchID & "-" & scopeLine.ScopeID,
                        BatchLineID:   _batchID & "-" & scopeLine.ScopeID,
                        BatchID:       _batchID,
                        ScopeID:       scopeLine.ScopeID,
                        SystemCode:    scopeLine.SystemCode,
                        EmployeeID:    scopeLine.EmployeeID,
                        EmployeeName:  scopeLine.EmployeeName,
                        StudyList:     scopeLine.StudyList,
                        TargetTA:      scopeLine.TargetTA,
                        Environment:   scopeLine.Environment,
                        CurrentAccess: If(scopeLine.CurrentAccess = true, "Yes", "No"),
                        Action:        scopeLine.SelectedAction,
                        ManagerEmail:  User().Email,
                        LineStatus:    "Pending",
                        TicketRunID:   Blank(),
                        TicketNumber:  Blank()
                    }
                )
            );

            Notify(
                "Submitted! " & CountRows(_changes) & " scope line(s) sent to Xiaoran.",
                NotificationType.Success
            );

            Refresh(Batches);
            Refresh(BatchLines);

            ClearCollect(
                colManagerScopes,
                AddColumns(
                    SortByColumns(
                        Filter(
                            EmployeeScopes,
                            Lower(Trim(ManagerEmail)) = varUserEmail &&
                            ActiveFlag = true &&
                            SystemCode = varSelectedSystemCode
                        ),
                        "EmployeeName", SortOrder.Ascending,
                        "TargetTA",     SortOrder.Ascending,
                        "Environment",  SortOrder.Ascending
                    ),
                    SelectedAction, "No Change"
                )
            ),

            Notify(
                "Submit failed. Please check your SharePoint column types and required fields.",
                NotificationType.Error
            )
        )
    )
)
```

